# Supabase Configuration
# Get these from your Supabase project settings > API

# Public Supabase URL (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public Supabase Anon Key (required for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role Key (optional, for server-side operations with elevated privileges)
# Keep this secret! Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin Password (for /admin page)
# In production, use a more secure authentication method
ADMIN_PASSWORD=ie6500admin
